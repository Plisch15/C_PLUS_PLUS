#include <iostream>
#include <cmath> // Необхідно для використання функції sqrt()

using namespace std;

// --- Задача 1: Опис функції isPrime ---
bool isPrime(int num) {
    // Числа менші або рівні 1 (0, 1, від'ємні) за визначенням не є простими
    if (num <= 1) {
        return false;
    }
    
    // Перевіряємо ділення на числа від 2 до квадратного кореня з num
    // Операція % (остача від ділення) допомагає знайти дільники
    for (int i = 2; i <= sqrt(num); i++) {
        if (num % i == 0) {
            return false; // Якщо остача 0, то знайшли дільник -> число складене
        }
    }
    
    return true; // Якщо дільників не знайдено -> число просте
}

// --- Задача 2: Виведення простих чисел у заданому діапазоні ---
int main(void) {
    for (int i = 0; i <= 21; i++) {
        if (isPrime(i)) {
            cout << i << " ";
        }
    }
    cout << endl;
    
    return 0;
}
