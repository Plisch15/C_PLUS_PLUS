#include <iostream>
#include <string>

using namespace std;

class Person
{
public:
    string name;
    int age;
    
    // --- Додані нові члени класу (поля) ---
    double weight;       // вага людини
    string occupation;   // професія/заняття
};

// Функція для виведення інформації через вказівник
void print(Person* person)
{
    // Зверніть увагу на використання оператора -> при роботі з вказівниками
    cout << person->name << " is " << person->age << " years old, weighs " 
         << person->weight << " kg, and works as a " << person->occupation << "." << endl;
}

int main()
{
    // --- Робота з першим об'єктом ---
    Person person1;
    person1.name = "Harry";
    person1.age = 23;
    person1.weight = 72.5;
    person1.occupation = "Auror";

    cout << "Meet " << person1.name << endl;
    print(&person1); // Передаємо адресу об'єкта
    
    cout << endl; // Для чистоти виведення

    // --- Робота з другим об'єктом (для експерименту) ---
    Person person2;
    person2.name = "Hermione";
    person2.age = 24;
    person2.weight = 55.0;
    person2.occupation = "Minister of Magic";

    cout << "Meet " << person2.name << endl;
    print(&person2);

    return 0;
}
