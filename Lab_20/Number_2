#include <iostream>

using namespace std;

class Square
{
// Секція private: дані доступні лише всередині самого класу
private:
    double side;
    double area;

// Секція public: методи доступні для виклику з будь-якого місця програми
public:
    // Конструктор за замовчуванням (ініціалізуємо початкові значення нулями)
    Square() {
        side = 0.0;
        area = 0.0;
    }

    // --- Метод-сетер set_side ---
    void set_side(double s) {
        // Якщо аргумент менший за 0, ігноруємо зміну (просто виходим з методу)
        if (s < 0) {
            return; 
        }
        
        // Оновлюємо обидва поля, гарантуючи математичну узгодженість
        side = s;
        area = s * s;
    }

    // --- Перенесений метод print ---
    void print() {
        cout << "Square: side=" << side << " area=" << area << endl;
    }
};

int main()
{
    Square s;
    
    // Спроба встановити коректне значення сторони
    s.set_side(4);
    s.print(); // Виведе: Square: side=4 area=16

    // Спроба встановити некоректне (від'ємне) значення сторони
    s.set_side(-5); 
    s.print(); // Зміна ігнорується, виведе попередні дані: Square: side=4 area=16

    // Спроба встановити інше коректне значення
    s.set_side(2.5);
    s.print(); // Виведе: Square: side=2.5 area=6.25

    return 0;
}
