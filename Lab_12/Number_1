#include <iostream>
using namespace std;

int main(void) {
    int vector[] = { 3, -5, 7, 10, -4, 14, 5, 2, -13 };
    int n = sizeof(vector) / sizeof(vector[0]);
    
    // --- Початок вашого коду ---
    
    // Вказівник на перший елемент масиву
    int *ptr = vector; 
    // Ініціалізуємо мінімум першим елементом
    int min = *ptr;    

    for (int i = 1; i < n; i++) {
        ptr++; // Переміщуємо вказівник на наступний елемент пам'яті
        if (*ptr < min) {
            min = *ptr; // Оновлюємо мінімум, якщо знайшли менше значення
        }
    }

    cout << "Найменший елемент масиву: " << min << endl;
    
    // --- Кінець вашого коду ---
    
    return 0;
}
