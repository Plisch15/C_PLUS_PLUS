#include <iostream>
using namespace std;

int main(void) {
    int matrix[10][10] = { };
    
    // --- Початок вашого коду ---
    
    // Створюємо вказівник на перший елемент двовимірного масиву
    int *ptr = &matrix[0][0]; 

    for (int i = 0; i < 10; i++) {
        for (int j = 0; j < 10; j++) {
            // Записуємо значення (рядок * стовпчик) у поточну комірку пам'яті
            *ptr = (i + 1) * (j + 1); 
            // Переміщуємо вказівник на наступну комірку в пам'яті
            ptr++; 
        }
    }
    
    // --- Кінець вашого коду ---

    for(int i = 0; i < 10; i++) {
        for(int j = 0; j < 10; j++) {
            cout.width(4);
            cout << matrix[i][j];
        }
        cout << endl;
    }
    return 0;
}
