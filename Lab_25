#include <iostream>

using namespace std;

// ==========================================
// БАЗОВИЙ АБСТРАКТНИЙ КЛАС
// ==========================================
class Tree {
public:
    // Чиста віртуальна функція (створює інтерфейс для малювання)
    virtual void draw() = 0;

    // Віртуальний деструктор для коректного звільнення пам'яті в поліморфних класах
    virtual ~Tree() {}
};

// ==========================================
// ПОХІДНІ КЛАСИ (РІЗНІ ТИПИ ДЕРЕВ)
// ==========================================

// Перший тип дерева (з похилими рисками всередині)
class SlashTree : public Tree {
public:
    void draw() override {
        cout << "Drawing 1:" << endl;
        cout << " /\\" << endl;
        cout << "//\\\\" << endl; // Екрануємо зворотний слеш '\\' як '\\\\'
    }
};

// Другий тип дерева (із зірочками всередині)
class StarTree : public Tree {
public:
    void draw() override {
        cout << "Drawing 2:" << endl;
        cout << " /\\" << endl;
        cout << "/**\\" << endl;
    }
};

// Третій тип дерева (із плюсиками всередині)
class PlusTree : public Tree {
public:
    void draw() override {
        cout << "Drawing 3:" << endl;
        cout << " /\\" << endl;
        cout << "/++\\" << endl;
    }
};

// ==========================================
// ГОЛОВНА ПРОГРАМА (ПОЛІМОРФНИЙ ВИКЛИК)
// ==========================================
int main() {
    const int TREE_COUNT = 3;

    // Створюємо масив вказівників на базовий клас Tree
    Tree* forest[TREE_COUNT];

    // Заповнюємо масив об'єктами різних похідних класів
    forest[0] = new SlashTree();
    forest[1] = new StarTree();
    forest[2] = new PlusTree();

    // Поліморфний цикл: викликаємо один і той самий метод draw()
    // для кожного елемента, але отримуємо різну поведінку
    for (int i = 0; i < TREE_COUNT; i++) {
        forest[i]->draw();
        cout << endl; // Пробіл між деревами
    }

    // Очищення динамічної пам'яті
    for (int i = 0; i < TREE_COUNT; i++) {
        delete forest[i];
    }

    return 0;
}
