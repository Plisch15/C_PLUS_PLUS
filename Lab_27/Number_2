#include <iostream>
#include <string>

using namespace std;

int main(void) {
    int a = 0, b = 0, c = 0;
    
    // Зчитуємо спочатку b, потім a відповідно до зразка
    cin >> b;
    cin >> a;
    
    try {
        // Перевіряємо, чи є спроба ділення на нуль
        if (b == 0) {
            throw string("Your input is not valid, you can't divide by zero.");
        }
        
        // Безпечне ділення
        c = a / b;
        cout << c << endl;
    }
    // Перехоплюємо виняток типу string
    catch (const string& error_message) {
        cout << error_message << endl;
    }
    
    return 0;
}
