#include <iostream>
#include <string>

using namespace std;

const int DivideByZero = 111;

float internaldiv(float arg1, float arg2)
{
    if (0 == arg2)
        throw DivideByZero; // Кидаємо int
    return arg1 / arg2;
}

// Функція просто повертає значення. 
// Якщо internaldiv кине виняток, керування автоматично повернеться в main.
float div(float arg1, float arg2) {
    return internaldiv(arg1, arg2);
}

int main(void) {
    float a, b;
    while(cin >> a) {
        cin >> b;
        try {
            float r = div(a, b);
            cout << r << endl;
        }
        // Ловимо системний код помилки 111
        catch (int e) {
            if (e == DivideByZero) {
                cout << "Are you kidding me?" << endl;
                cout << "Your input is not valid. You can't divide by zero." << endl;
            }
        }
    }
    return 0;
}
