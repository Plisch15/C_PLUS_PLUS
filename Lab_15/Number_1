#include <iostream>
using namespace std;

bool isLeap(int year) {
    // --- Початок вашого коду ---
    
    // Якщо рік ділиться на 400 — він точно високосний
    if (year % 400 == 0) {
        return true;
    }
    // Якщо ділиться на 100 (але не на 400, бо це ми перевірили вище) — він НЕ високосний
    if (year % 100 == 0) {
        return false;
    }
    // В усіх інших випадках достатньо перевірити ділення на 4
    if (year % 4 == 0) {
        return true;
    }
    
    return false; // Якщо жодна умова не виконалась, рік звичайний
    
    // --- Кінець вашого коду ---
}

int main(void) {
    for(int yr = 1995; yr < 2017; yr++)
        cout << yr << " -> " << isLeap(yr) << endl;
    return 0;
}
